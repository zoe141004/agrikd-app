# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
mobile_app/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
mobile_app/android/app/debug
mobile_app/android/app/profile
mobile_app/android/app/release

# Python / MLOps
venv*/
.venv/
__pycache__/
*.py[cod]
*$py.class
tmp_*

# Model artifacts (large binaries - tracked via DVC/external hosting)
model_checkpoints_student/
*.onnx
*.tflite
*.engine
# But keep bundled app models
!mobile_app/assets/models/**/*.tflite

# Datasets (large, tracked via DVC)
# DVC creates per-directory .gitignore to ignore actual data files.
# We un-ignore data/ so .dvc tracking files and .gitignore files are committed.
/data/**
!/data/**/
!data/**/*.dvc
!data/**/.gitignore

# Environment files (secrets)
.env
.env.*
!.env.example
!admin-dashboard/.env.example
supabase_info.md

# Admin Dashboard
admin-dashboard/node_modules/
admin-dashboard/dist/

# Android machine-specific
mobile_app/android/local.properties
mobile_app/android/.gradle/

# Secrets — NEVER commit (rotate if exposed in git history)
.dvc/gdrive-sa.json
.dvc/config.local
jetson/config/config.json

# Build reports
**/build/reports/

# Claude Code agent state
.claude/
