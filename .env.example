# ==============================================
# AgriKD Environment Variables (Single Source of Truth)
# ==============================================
# Copy this file to .env and fill in your values.
# Then run: python sync_env.py
#
# This will auto-generate:
#   - admin-dashboard/.env  (VITE_ prefixed for Vite)
#   - jetson/config/config.json  (sync block updated)
#
# Flutter reads this file directly via flutter_dotenv (local dev)
# or via --dart-define flags (CI/CD production builds).

# --- Required for Flutter App + Admin Dashboard ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_WEB_CLIENT_ID=

# --- Required for CI/CD and admin operations (service-level access) ---
# Only needed if running export-data, model-pipeline, or dataset-upload workflows locally.
SUPABASE_SERVICE_ROLE_KEY=

# --- Required for DVC dataset operations ---
# Google Drive service account JSON (base64 encoded for CI, or file path for local).
# In GitHub Actions, this is set as a repository secret.
GDRIVE_CREDENTIALS_DATA=

# --- Error Tracking (Sentry) ---
# DSN for Sentry error reporting. Used by Flutter app and Admin Dashboard.
# Create a project at https://sentry.io and paste the DSN here.
SENTRY_DSN=

# --- Optional: Vercel Deploy Hook ---
# Used by deploy.yml to trigger admin dashboard deployment.
# Vercel → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=

# --- Optional: Kaggle credentials ---
# Only needed for dataset-upload.yml with source=kaggle.
# Get from https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=
